{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Dexploit Streaming API",
    "version": "1.0.0",
    "description": "Real-time WebSocket streams: raw swaps, swap-event OHLCV candles, and pump.fun token lifecycle events. Authenticate with `?api_key=\u2026` or `Authorization: Bearer \u2026`.",
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": {
    "production": {
      "host": "ws.dexploit.dev",
      "pathname": "/",
      "protocol": "wss",
      "description": "Production WebSocket edge. TLS required. Authenticate with `?api_key=ohlcv_live_sk_\u2026` or `Authorization: Bearer \u2026`.",
      "security": [
        {
          "$ref": "#/components/securitySchemes/ApiKeyQuery"
        }
      ]
    }
  },
  "channels": {
    "swaps": {
      "address": "/ws/swaps",
      "title": "Raw swap stream",
      "description": "Every swap on every indexed Solana DEX, optionally filtered by pool, token, trader, dex, SOL amount, or direction. Send a `subscribe` message after connecting to set filters \u2014 by default, every swap flows through.",
      "messages": {
        "subscribed": {
          "$ref": "#/components/messages/SwapsSubscribed"
        },
        "unsubscribed": {
          "$ref": "#/components/messages/SwapsUnsubscribed"
        },
        "swap": {
          "$ref": "#/components/messages/SwapEvent"
        },
        "poolEvent": {
          "$ref": "#/components/messages/PoolEvent"
        },
        "roomMessage": {
          "$ref": "#/components/messages/SwapsRoomMessage"
        },
        "joined": {
          "$ref": "#/components/messages/SwapsJoined"
        },
        "left": {
          "$ref": "#/components/messages/SwapsLeft"
        },
        "pong": {
          "$ref": "#/components/messages/Pong"
        },
        "error": {
          "$ref": "#/components/messages/StreamError"
        },
        "subscribe": {
          "$ref": "#/components/messages/SwapsSubscribe"
        },
        "unsubscribe": {
          "$ref": "#/components/messages/SwapsUnsubscribe"
        },
        "join": {
          "$ref": "#/components/messages/SwapsJoin"
        },
        "leave": {
          "$ref": "#/components/messages/SwapsLeave"
        },
        "ping": {
          "$ref": "#/components/messages/Ping"
        }
      }
    },
    "ohlcv": {
      "address": "/ws/ohlcv",
      "title": "OHLCV candle stream",
      "description": "Live OHLCV bars for one or more pools / timeframes. Bars are emitted as they're built \u2014 `is_closed: false` mid-bar, `is_closed: true` on the final tick.",
      "messages": {
        "connected": {
          "$ref": "#/components/messages/OhlcvConnected"
        },
        "subscribed": {
          "$ref": "#/components/messages/OhlcvSubscribed"
        },
        "ohlcv": {
          "$ref": "#/components/messages/OhlcvFrame"
        },
        "error": {
          "$ref": "#/components/messages/StreamError"
        },
        "subscribe": {
          "$ref": "#/components/messages/OhlcvSubscribe"
        }
      }
    },
    "pumpLifecycle": {
      "address": "/ws/pump-lifecycle",
      "title": "Pump.fun lifecycle stream",
      "description": "Every connected client receives every lifecycle event \u2014 there is no `subscribe` message. Filter client-side by `type`, `mint`, or `creator`.",
      "messages": {
        "mintCreated": {
          "$ref": "#/components/messages/PumpMintCreated"
        },
        "completing": {
          "$ref": "#/components/messages/PumpCompleting"
        },
        "graduated": {
          "$ref": "#/components/messages/PumpGraduated"
        }
      }
    }
  },
  "operations": {
    "receiveSwapsSwap": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/swap"
        }
      ],
      "summary": "Swap event",
      "description": "One executed swap on a Solana DEX, normalized across protocols."
    },
    "receiveSwapsPoolEvent": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/poolEvent"
        }
      ],
      "summary": "Pool event (filter-mode)",
      "description": "Non-swap pool activity — `lp_deposit`, `lp_withdraw`, `token_burn`, and the server-classified `rug_detected`. Delivered on an unfiltered or `tokens`/`pools`-filtered connection, interleaved with swaps. Demux on `event_type`. Only the `tokens`/`pools` filters apply to pool events; `dexes`/`min_sol`/`max_sol`/`traders`/`is_buy`/`wallet_tags` are swap-only. NOTE: `timestamp_ms` is epoch **milliseconds** (the `swap` frame uses `timestamp` in **seconds**); `quote_amount`/`lp_sol_pulled` are **lamports** despite no `_sol` suffix; `base_amount`/`amount_atomic` are atomic units; Meteora DAMM v2 (`dex=7`) saturates `lp_token_amount` to `u64::MAX`."
    },
    "receiveSwapsRoomMessage": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/roomMessage"
        }
      ],
      "summary": "Room message (room-mode)",
      "description": "In room-mode, a swap OR pool event scoped to a joined room. The event payload is nested under `data` and carries `event_type` but NOT a top-level `type` — the **dual-frame trap** (same event, two on-wire shapes by mode). `transaction:{mint}` rooms interleave swaps + pool events + `rug_detected`."
    },
    "receiveSwapsJoined": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/joined"
        }
      ],
      "summary": "Join ack",
      "description": "Sent after a successful `join`. The first `join` locks the connection into room-mode (mode-exclusive with filter-mode)."
    },
    "receiveSwapsLeft": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/left"
        }
      ],
      "summary": "Leave ack"
    },
    "receiveSwapsSubscribed": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/subscribed"
        }
      ],
      "summary": "Connection / subscribe ack",
      "description": "Sent on connect AND after each successful `subscribe`. The connect-time frame includes a `client-N` ID for log correlation."
    },
    "receiveSwapsUnsubscribed": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/unsubscribed"
        }
      ],
      "summary": "Unsubscribe ack"
    },
    "receiveSwapsPong": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/pong"
        }
      ],
      "summary": "Pong",
      "description": "Reply to a client `ping`. Send a `ping` every ~25\u201330s to keep the connection from idling out."
    },
    "receiveSwapsError": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/error"
        }
      ],
      "summary": "Stream error",
      "description": "Validation failure, auth issue, or server-side error. Connection usually stays open after a recoverable error."
    },
    "sendSwapsSubscribe": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/subscribe"
        }
      ],
      "summary": "Set filters",
      "description": "Replaces the active filter set. Empty `filters` means \"every swap on every pool\"."
    },
    "sendSwapsUnsubscribe": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/unsubscribe"
        }
      ],
      "summary": "Clear filters"
    },
    "sendSwapsPing": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/ping"
        }
      ],
      "summary": "Heartbeat",
      "description": "Optional keepalive. Server replies with `pong`. Recommended every 25\u201330 seconds."
    },
    "sendSwapsJoin": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/join"
        }
      ],
      "summary": "Join a room",
      "description": "Subscribe to a room such as `transaction:<mint>` or `transaction:<mint>:<pool>`. The first `join` locks the connection into room-mode \u2014 mode-exclusive with `subscribe`/filter-mode. `transaction:{mint}` rooms interleave swaps + pool events + `rug_detected`."
    },
    "sendSwapsLeave": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/swaps"
      },
      "messages": [
        {
          "$ref": "#/channels/swaps/messages/leave"
        }
      ],
      "summary": "Leave a room"
    },
    "receiveOhlcvOhlcv": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/ohlcv"
      },
      "messages": [
        {
          "$ref": "#/channels/ohlcv/messages/ohlcv"
        }
      ],
      "summary": "Candle update",
      "description": "One bar update for a subscribed (pool, timeframe). NOTE: `volume_sol` is in **lamports** despite the name (divide by 1e9 for SOL); `volume_token` is in base units (divide by 10**quote_decimals)."
    },
    "receiveOhlcvConnected": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/ohlcv"
      },
      "messages": [
        {
          "$ref": "#/channels/ohlcv/messages/connected"
        }
      ],
      "summary": "Connect hello",
      "description": "Sent once on connect with a UUID `client_id` and the index inception timestamp."
    },
    "receiveOhlcvSubscribed": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/ohlcv"
      },
      "messages": [
        {
          "$ref": "#/channels/ohlcv/messages/subscribed"
        }
      ],
      "summary": "Subscribe ack",
      "description": "Sent after each successful `subscribe`. `pairs` is the new total subscribed pool count; `subjects` is the count of (pool \u00d7 timeframe) Cartesian-product subjects on the NATS backbone."
    },
    "receiveOhlcvError": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/ohlcv"
      },
      "messages": [
        {
          "$ref": "#/channels/ohlcv/messages/error"
        }
      ],
      "summary": "Stream error",
      "description": "Validation failure, auth issue, or server-side error. Connection usually stays open after a recoverable error."
    },
    "sendOhlcvSubscribe": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/ohlcv"
      },
      "messages": [
        {
          "$ref": "#/channels/ohlcv/messages/subscribe"
        }
      ],
      "summary": "Subscribe to (pools \u00d7 timeframes)",
      "description": "Both arrays are required. Server emits frames for every (pool \u00d7 timeframe) pair."
    },
    "receivePumpLifecycleMintCreated": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/pumpLifecycle"
      },
      "messages": [
        {
          "$ref": "#/channels/pumpLifecycle/messages/mintCreated"
        }
      ],
      "summary": "Mint created",
      "description": "A new pump.fun token has been minted. Bonding curve sits at 0%."
    },
    "receivePumpLifecycleCompleting": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/pumpLifecycle"
      },
      "messages": [
        {
          "$ref": "#/channels/pumpLifecycle/messages/completing"
        }
      ],
      "summary": "Bonding curve completing",
      "description": "The pump.fun bonding curve has reached its threshold and migration to pumpswap is imminent. `bonding_pct` will read 1.0."
    },
    "receivePumpLifecycleGraduated": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/pumpLifecycle"
      },
      "messages": [
        {
          "$ref": "#/channels/pumpLifecycle/messages/graduated"
        }
      ],
      "summary": "Token graduated to pumpswap",
      "description": "The token has finished bonding and an AMM pool exists at `new_pool`. Use that pair address on the candles / swaps endpoints."
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyQuery": {
        "type": "httpApiKey",
        "in": "query",
        "name": "api_key",
        "description": "`?api_key=ohlcv_live_sk_\u2026` appended to the connection URL. Browser-friendly; the only option in environments where you can't set headers."
      }
    },
    "messages": {
      "SwapsSubscribed": {
        "name": "subscribed",
        "title": "Connection / subscribe ack",
        "summary": "Sent on connect AND after each successful `subscribe`. The connect-time frame includes a `client-N` ID for log correlation.",
        "payload": {
          "$ref": "#/components/schemas/SwapsSubscribedAck"
        }
      },
      "SwapsUnsubscribed": {
        "name": "unsubscribed",
        "title": "Unsubscribe ack",
        "payload": {
          "$ref": "#/components/schemas/StreamSimpleAck"
        }
      },
      "SwapEvent": {
        "name": "swap",
        "title": "Swap event",
        "summary": "One executed swap on a Solana DEX, normalized across protocols.",
        "payload": {
          "$ref": "#/components/schemas/WsSwapFrame"
        }
      },
      "PoolEvent": {
        "name": "pool_event",
        "title": "Pool event",
        "summary": "Non-swap pool activity (filter-mode): LP deposit / withdraw, token burn, or the server-classified rug signal. All four share `type: \"pool_event\"` — demux on `event_type`. `lp_withdraw` is the real-time LP-removal signal; `rug_detected` is the classified version.",
        "payload": {
          "$ref": "#/components/schemas/WsPoolEventFrame"
        }
      },
      "SwapsRoomMessage": {
        "name": "message",
        "title": "Room message",
        "summary": "Room-mode delivery wrapper. The swap or pool event is nested under `data`; `data` carries `event_type` but NOT a top-level `type` (dual-frame trap).",
        "payload": {
          "$ref": "#/components/schemas/WsRoomMessageFrame"
        }
      },
      "SwapsJoin": {
        "name": "join",
        "title": "Join room",
        "summary": "Subscribe to a room (e.g. `transaction:<mint>` or `transaction:<mint>:<pool>`). First `join` locks room-mode.",
        "payload": {
          "$ref": "#/components/schemas/SwapsJoinBody"
        }
      },
      "SwapsLeave": {
        "name": "leave",
        "title": "Leave room",
        "payload": {
          "$ref": "#/components/schemas/SwapsLeaveBody"
        }
      },
      "SwapsJoined": {
        "name": "joined",
        "title": "Join ack",
        "summary": "Sent after a successful `join`.",
        "payload": {
          "$ref": "#/components/schemas/SwapsRoomAck"
        }
      },
      "SwapsLeft": {
        "name": "left",
        "title": "Leave ack",
        "payload": {
          "$ref": "#/components/schemas/SwapsRoomAck"
        }
      },
      "Pong": {
        "name": "pong",
        "title": "Pong",
        "summary": "Reply to a client `ping`. Send a `ping` every ~25\u201330s to keep the connection from idling out.",
        "payload": {
          "type": "object",
          "properties": {
            "type": {
              "const": "pong"
            }
          }
        }
      },
      "StreamError": {
        "name": "error",
        "title": "Stream error",
        "summary": "Validation failure, auth issue, or server-side error. Connection usually stays open after a recoverable error.",
        "payload": {
          "$ref": "#/components/schemas/StreamErrorBody"
        }
      },
      "SwapsSubscribe": {
        "name": "subscribe",
        "title": "Set filters",
        "summary": "Replaces the active filter set. Empty `filters` means \"every swap on every pool\".",
        "payload": {
          "$ref": "#/components/schemas/SwapsSubscribeBody"
        }
      },
      "SwapsUnsubscribe": {
        "name": "unsubscribe",
        "title": "Clear filters",
        "payload": {
          "type": "object",
          "properties": {
            "type": {
              "const": "unsubscribe"
            }
          }
        }
      },
      "Ping": {
        "name": "ping",
        "title": "Heartbeat",
        "summary": "Optional keepalive. Server replies with `pong`. Recommended every 25\u201330 seconds.",
        "payload": {
          "type": "object",
          "properties": {
            "type": {
              "const": "ping"
            }
          }
        }
      },
      "OhlcvConnected": {
        "name": "connected",
        "title": "Connect hello",
        "summary": "Sent once on connect with a UUID `client_id` and the index inception timestamp.",
        "payload": {
          "$ref": "#/components/schemas/OhlcvConnectedBody"
        }
      },
      "OhlcvSubscribed": {
        "name": "subscribed",
        "title": "Subscribe ack",
        "summary": "Sent after each successful `subscribe`. `pairs` is the new total subscribed pool count; `subjects` is the count of (pool \u00d7 timeframe) Cartesian-product subjects on the NATS backbone.",
        "payload": {
          "$ref": "#/components/schemas/OhlcvSubscribedBody"
        }
      },
      "OhlcvFrame": {
        "name": "ohlcv",
        "title": "Candle update",
        "summary": "One bar update for a subscribed (pool, timeframe). NOTE: `volume_sol` is in **lamports** despite the name (divide by 1e9 for SOL); `volume_token` is in base units (divide by 10**quote_decimals).",
        "payload": {
          "$ref": "#/components/schemas/WsOhlcvFrame"
        }
      },
      "OhlcvSubscribe": {
        "name": "subscribe",
        "title": "Subscribe to (pools \u00d7 timeframes)",
        "summary": "Both arrays are required. Server emits frames for every (pool \u00d7 timeframe) pair.",
        "payload": {
          "$ref": "#/components/schemas/OhlcvSubscribeBody"
        }
      },
      "PumpMintCreated": {
        "name": "mint_created",
        "title": "Mint created",
        "summary": "A new pump.fun token has been minted. Bonding curve sits at 0%.",
        "payload": {
          "$ref": "#/components/schemas/PumpMintCreatedBody"
        }
      },
      "PumpCompleting": {
        "name": "completing",
        "title": "Bonding curve completing",
        "summary": "The pump.fun bonding curve has reached its threshold and migration to pumpswap is imminent. `bonding_pct` will read 1.0.",
        "payload": {
          "$ref": "#/components/schemas/PumpCompletingBody"
        }
      },
      "PumpGraduated": {
        "name": "graduated",
        "title": "Token graduated to pumpswap",
        "summary": "The token has finished bonding and an AMM pool exists at `new_pool`. Use that pair address on the candles / swaps endpoints.",
        "payload": {
          "$ref": "#/components/schemas/PumpGraduatedBody"
        }
      }
    },
    "schemas": {
      "Dex": {
        "type": "string",
        "enum": [
          "pumpfun",
          "pumpswap",
          "raydium_amm",
          "raydium_clmm",
          "raydium_cpmm",
          "orca",
          "meteora_damm_v2",
          "meteora_dbc",
          "meteora_dlmm",
          "meteora_pools"
        ],
        "description": "Lowercase snake_case DEX name. Note: on the WebSocket feed `dex` is the string name, but on the REST `/swaps*` endpoints it's an integer ID \u2014 these surfaces are intentionally different."
      },
      "Timeframe": {
        "type": "string",
        "enum": [
          "1s",
          "30s",
          "1m",
          "5m",
          "15m",
          "1h",
          "4h",
          "1d"
        ]
      },
      "SwapsSubscribedAck": {
        "type": "object",
        "properties": {
          "type": {
            "const": "subscribed"
          },
          "message": {
            "type": "string",
            "example": "Connected as client-196. Send {\"type\":\"subscribe\",\"filters\":{...}} to set filters."
          }
        }
      },
      "StreamSimpleAck": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "StreamErrorBody": {
        "type": "object",
        "properties": {
          "type": {
            "const": "error"
          },
          "message": {
            "type": "string",
            "example": "invalid subscribe: timeframes empty"
          },
          "error": {
            "type": "string",
            "description": "Some errors return just `{\"error\":\"\u2026\"}` instead of `{\"type\":\"error\",\"message\":\"\u2026\"}` \u2014 handle both.",
            "example": "invalid subscribe: pair_addresses required"
          }
        }
      },
      "SwapsSubscribeBody": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "const": "subscribe"
          },
          "filters": {
            "type": "object",
            "description": "All filters combine as AND. Set to `null` or omit to disable a filter.",
            "properties": {
              "pools": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Pool / pair address \u2014 usually the most useful filter."
              },
              "tokens": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Token mints. Matches any pool that trades this token."
              },
              "traders": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Wallet addresses."
              },
              "dexes": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Dex"
                }
              },
              "min_sol": {
                "type": "integer",
                "format": "int64",
                "description": "Lamports. 1 SOL = 1e9 lamports."
              },
              "max_sol": {
                "type": "integer",
                "format": "int64"
              },
              "is_buy": {
                "type": "boolean",
                "description": "`true` for buys only, `false` for sells only."
              }
            }
          }
        }
      },
      "WsSwapFrame": {
        "type": "object",
        "description": "Streaming swap shape. Differs from the REST `Swap` schema \u2014 see the *Wire format gotchas* section in the WebSocket page.",
        "properties": {
          "type": {
            "const": "swap"
          },
          "signature": {
            "type": "string"
          },
          "slot": {
            "type": "integer",
            "format": "int64"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "Unix epoch **seconds** (REST candles use ISO; REST swaps use ms \u2014 yes, all three are different)."
          },
          "dex": {
            "$ref": "#/components/schemas/Dex"
          },
          "swap_type": {
            "type": "string",
            "enum": [
              "buy",
              "sell"
            ],
            "description": "**Different from REST**: streaming uses `swap_type` (string), REST uses `is_buy` (bool)."
          },
          "trader": {
            "type": "string"
          },
          "token_mint": {
            "type": "string"
          },
          "pool_address": {
            "type": "string"
          },
          "amount_in": {
            "type": "integer",
            "format": "int64",
            "description": "Base-unit amount of whichever side the trader sold. For buys, this is the input SOL."
          },
          "amount_out": {
            "type": "integer",
            "format": "int64"
          },
          "sol_amount": {
            "type": "integer",
            "format": "int64",
            "description": "Lamports."
          },
          "token_amount": {
            "type": "integer",
