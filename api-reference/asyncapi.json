      "WsRugRecordFrame": {
        "type": "object",
        "description": "`rug_detected` — server-side classified rug / drain signal derived from an `lp_withdraw` or `lp_burn`. Fires only on already-graduated AMM pools (PumpSwap/RaydiumAmm/MeteoraDammV2), never the pump bonding curve. Pump graduation-migrations are EXCLUDED.",
        "properties": {
          "type": {
            "const": "pool_event"
          },
          "event_type": {
            "const": "rug_detected"
          },
          "timestamp_ms": {
            "type": "integer",
            "format": "int64",
            "description": "Epoch **milliseconds**."
          },
          "slot": {
            "type": "integer",
            "format": "int64"
          },
          "signature": {
            "type": "string",
            "description": "Base58 signature of the triggering withdraw/burn."
