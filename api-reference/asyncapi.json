          "pool_address": {
            "type": "string"
          },
          "token_mint": {
            "type": "string"
          },
          "dex": {
            "$ref": "#/components/schemas/DexId"
          },
          "lp_sol_pulled": {
            "type": "integer",
            "format": "int64",
            "description": "SOL liquidity removed, in **lamports**. Divide by `1e9` for SOL."
          },
          "drained_pct": {
            "type": "number",
            "format": "float",
            "description": "Fraction of pool liquidity removed, 0..1."
          },
          "classification": {
            "type": "string",
            "enum": [
              "RUGGED",
              "LIQUIDITY_DRAINING"
            ],
            "description": "`RUGGED` when >95% of liquidity removed; `LIQUIDITY_DRAINING` when 50–95%."
