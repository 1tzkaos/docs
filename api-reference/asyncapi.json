      "WsLpEventFrame": {
        "type": "object",
        "description": "`lp_deposit` / `lp_withdraw` liquidity event. No buy/sell side and no price field.",
        "properties": {
          "type": {
            "const": "pool_event"
          },
          "event_type": {
            "type": "string",
            "enum": [
              "lp_deposit",
              "lp_withdraw"
            ]
          },
          "timestamp_ms": {
            "type": "integer",
            "format": "int64",
            "description": "Epoch **milliseconds** — the `swap` frame uses `timestamp` in epoch **seconds** (1000×)."
          },
          "slot": {
            "type": "integer",
            "format": "int64"
          },
          "signature": {
            "type": "string",
            "description": "Base58 transaction signature."
          },
          "user": {
            "type": "string",
            "description": "Wallet that added/removed the LP."
          },
          "pool_address": {
            "type": "string",
            "description": "On-chain pool / LP account (elsewhere called `pair_address`)."
          },
          "token_mint": {
            "type": "string"
          },
          "base_amount": {
            "type": "integer",
            "format": "int64",
            "description": "Memecoin side, **atomic** units. Divide by `10**decimals` (~6 for pump). Decimals are NOT carried on the event."
          },
          "quote_amount": {
            "type": "integer",
            "format": "int64",
            "description": "SOL / WSOL side in **lamports** despite no `_sol` suffix. Divide by `1e9` for SOL."
          },
          "lp_token_amount": {
            "type": "integer",
            "format": "int64",
            "description": "LP tokens, atomic. Meteora DAMM v2 (`dex=7`) **saturates this to `u64::MAX`** — use `base_amount`+`quote_amount` for value."
          },
          "drained_pct": {
            "type": "number",
            "format": "float",
            "description": "Fraction of pool liquidity removed by this event, 0..1. Constant-product pools use the LP-supply ratio; Meteora CL uses the SOL-reserve ratio. `0.0` when not computable."
          },
          "pool_base_reserve_after": {
            "type": "integer",
            "format": "int64",
            "description": "Post-event pool reserve, base side (atomic). `0` when N/A."
          },
          "pool_quote_reserve_after": {
            "type": "integer",
            "format": "int64",
            "description": "Post-event pool reserve, quote side (**lamports**). `0` when N/A."
          },
          "lp_supply_after": {
            "type": "integer",
            "format": "int64",
            "description": "Post-event total LP supply. Constant-product only — `0` for Meteora."
          },
          "dex": {
            "$ref": "#/components/schemas/DexId"
          }
        },
        "example": {
          "type": "pool_event",
          "event_type": "lp_withdraw",
          "timestamp_ms": 1717000000000,
          "slot": 270123456,
          "signature": "5Qx2vG7mB1qf6n7dWbN4d8Zp5gQ3sR9tH2cJ4kL6mN8pVxYzA1bC3dE5fG7hJ9kL2mN4pQ6rS8tU0vW2xY4zA6",
