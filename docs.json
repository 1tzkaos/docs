{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dexploit",
  "colors": {
    "primary": "#FFFFFF",
    "light": "#FFFFFF",
    "dark": "#0A0A0A"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/pairs-vs-tokens",
              "concepts/swap-event-ohlcv",
              "concepts/timeframes-resolution",
              "concepts/quotas-errors"
            ]
          },
          {
            "group": "Streaming",
            "pages": [
              "streaming/websocket",
              "streaming/grpc",
              "streaming/reconnect-backpressure"
            ]
          },
          {
            "group": "Examples",
            "pages": ["examples"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Pairs",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/v1/pairs"
            ]
          },
          {
            "group": "Candles (OHLCV)",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/v1/candles",
              "GET /api/v1/candles/latest"
            ]
          },
          {
            "group": "Swaps",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /swaps",
              "GET /swaps/range",
              "GET /swaps/whale",
              "GET /swaps/{signature}",
              "GET /swaps/trader/{wallet}",
              "GET /swaps/token/{mint}"
            ]
          },
          {
            "group": "Stats & trends",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /stats/global",
              "GET /stats/trader/{wallet}",
              "GET /stats/token/{mint}",
              "GET /trending",
              "GET /api/v1/top-movers",
              "GET /api/v1/protocols",
              "GET /api/v1/stats"
            ]
          },
          {
            "group": "GraphQL",
            "pages": ["api-reference/graphql"]
          },
          {
            "group": "Health",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /health",
              "GET /ready"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://www.dexploit.dev/dashboard",
          "icon": "gauge"
        },
        {
          "anchor": "GitHub Examples",
          "href": "https://github.com/DexploitV1/Dexploit-Examples",
          "icon": "github"
        },
        {
          "anchor": "Status",
          "href": "https://www.dexploit.dev/status",
          "icon": "heart-pulse"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://www.dexploit.dev/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://www.dexploit.dev/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/dexploit",
      "github": "https://github.com/DexploitV1"
    }
  }
}
