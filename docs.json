{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dexploit",
  "description": "Real-time and historical Solana DEX data: swap streams, swap-event OHLCV candles, token intel, wallet tagging, and pump.fun lifecycle events. Built for dApp teams, dashboards, and data builders who'd rather skip the parsing tax.",
  "metadata": {
    "og:site_name":   "Dexploit Docs",
    "og:type":        "website",
    "og:image":       "/logo/light.png",
    "og:locale":      "en_US",
    "twitter:card":   "summary_large_image",
    "twitter:site":   "@dexploit",
    "twitter:image":  "/logo/light.png",
    "robots":         "index, follow",
    "googlebot":      "index, follow, max-image-preview:large, max-snippet:-1",
    "article:author": "Dexploit"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "keywords": "solana, dex, defi, ohlcv, candles, pumpfun, pumpswap, raydium, meteora, websocket, grpc, api, real-time, swap stream, token intel, wallet tagging, screener, mev, trading, solana data, solana api, pumpfun api, raydium api"
    }
  },
  "colors": {
    "primary": "#FFFFFF",
    "light": "#FFFFFF",
    "dark": "#0A0A0A"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/pairs-vs-tokens",
              "concepts/swap-event-ohlcv",
              "concepts/timeframes-resolution",
              "concepts/quotas-errors"
            ]
          },
          {
            "group": "Streaming",
            "pages": [
              "streaming/websocket",
              "streaming/pump-lifecycle",
              "streaming/grpc",
              "streaming/reconnect-backpressure"
            ]
          },
          {
            "group": "Examples",
            "pages": ["examples"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Pairs",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/v1/pairs"
            ]
          },
          {
            "group": "Candles (OHLCV)",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/v1/candles",
              "GET /api/v1/candles/latest"
            ]
          },
          {
            "group": "Swaps",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /swaps",
              "GET /swaps/range",
              "GET /swaps/whale",
              "GET /swaps/{signature}",
              "GET /swaps/trader/{wallet}",
              "GET /swaps/token/{mint}"
            ]
          },
          {
            "group": "Stats & trends",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /stats/global",
              "GET /stats/trader/{wallet}",
              "GET /stats/token/{mint}",
              "GET /stats/tokens",
              "GET /trending",
              "GET /api/v1/top-movers",
              "GET /api/v1/protocols",
              "GET /api/v1/stats"
            ]
          },
          {
            "group": "Tokens",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /tokens",
              "GET /tokens/{mint}",
              "GET /tokens/{mint}/audit",
              "GET /tokens/{mint}/intel"
            ]
          },
          {
            "group": "Wallet intel",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /wallets/{wallet}/tags",
              "GET /tokens/{mint}/wallet-tag-counts"
            ]
          },
          {
            "group": "Screener",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /screener"
            ]
          },
          {
            "group": "Pool events",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /pool-events"
            ]
          },
          {
            "group": "Pump lifecycle",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /pump-lifecycle"
            ]
          },
          {
            "group": "Streaming",
            "pages": [
              "streaming/websocket",
              "streaming/pump-lifecycle",
              "streaming/grpc",
              "streaming/reconnect-backpressure"
            ]
          },
          {
            "group": "GraphQL",
            "pages": ["api-reference/graphql"]
          },
          {
            "group": "Health",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /health",
              "GET /ready"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://www.dexploit.dev/dashboard",
          "icon": "gauge"
        },
        {
          "anchor": "GitHub Examples",
          "href": "https://github.com/DexploitV1/Dexploit-Examples",
          "icon": "github"
        },
        {
          "anchor": "Status",
          "href": "https://www.dexploit.dev/status",
          "icon": "heart-pulse"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://www.dexploit.dev/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://www.dexploit.dev/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/dexploit",
      "github": "https://github.com/DexploitV1"
    }
  }
}
